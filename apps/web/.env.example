# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres direct connection (used by LangGraph checkpointer — must be the direct URL, not the pooler)
# In Supabase: Settings → Database → Connection string → URI (mode: Session/Direct, not Transaction)
DATABASE_URL=

# OpenRouter
OPENROUTER_API_KEY=

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Notion OAuth — public integration (optional)
# https://www.notion.so/my-integrations — redirect URI: {your-origin}/api/integrations/notion/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
# Optional: exact callback URL if request origin is wrong (proxies). Example: http://localhost:3000/api/integrations/notion/callback
NOTION_REDIRECT_URI=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_BASE_URL=

# OAuth encryption
OAUTH_ENCRYPTION_KEY=

# Bash tool (optional, high-risk)
# Set to "true" to enable execution of bash commands on the server host.
# Leave unset or set to any other value to disable (fail-closed default).
BASH_TOOL_ENABLED=
# Absolute path to use as working directory for bash commands.
# Defaults to process.cwd() if unset or invalid.
BASH_TOOL_CWD=

# File tools (optional, read_file / write_file / edit_file)
# Set FILE_TOOLS_ENABLED=true to enable file read/write/edit operations on the server host.
# Leave unset or set to any other value to disable (fail-closed default).
# Paths passed to file tools can be absolute or relative to the server process working directory,
# matching the same behaviour as the bash tool — no root confinement is enforced.
FILE_TOOLS_ENABLED=

# Scheduled tasks cron runner
# A secret token that Supabase Cron (or any external caller) must send in the
# Authorization header as "Bearer <value>" when hitting /api/cron/scheduled-tasks.
# Leave empty to disable authentication (not recommended for production).
CRON_SECRET=

# Next.js (optional)
# Comma-separated hostnames allowed for dev HMR (e.g. cloudflared, custom ngrok).
# Typical ngrok URLs (*.ngrok-free.app / *.ngrok-free.dev) are already allowed in next.config.ts.
NEXT_ALLOWED_DEV_ORIGINS=
